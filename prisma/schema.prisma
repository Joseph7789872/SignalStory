// SignalStory — V1 data model
// Agent outputs are stored as JSON columns whose shape is owned by the Zod
// schemas in lib/agents/schemas.ts. Relational tables are used for entities
// that are queried/filtered.

generator client {
  provider        = "prisma-client-js"
  // pgvector support for the V5 memory store (MemoryChunk.embedding).
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  // Supabase: pooled connection (port 6543, ?pgbouncer=true) for the app runtime.
  url        = env("DATABASE_URL")
  // Direct connection (port 5432) for migrations / db:push.
  directUrl  = env("DIRECT_URL")
  // pgvector: db push emits CREATE EXTENSION; required by MemoryChunk.embedding.
  extensions = [vector]
}

// --- Identity / tenancy ---

model Organization {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  onboardedAt DateTime? // null = guided onboarding not yet completed/skipped
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  users     User[]
  profile   OrganizationProfile?
  founder   FounderProfile?
  brandVoice BrandVoice?
  editorial EditorialStrategy?
  invites   OrganizationInvite[]
  integrations IntegrationConnection[]
  signals   Signal[]
  promptTemplates PromptTemplate[]
  memoryDocs MemoryDoc[]
  subscription Subscription?
  scheduledPosts ScheduledPost[]
  socialAccounts SocialAccount[]
  auditLogs    AuditLog[]
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

// V2: team invitations. Acceptance is implicit on the invitee's first sign-in
// (matched by email in getOrCreateAuthContext) — no email-delivery service.
model OrganizationInvite {
  id        String       @id @default(cuid())
  orgId     String
  email     String
  role      Role         @default(MEMBER)
  status    InviteStatus @default(PENDING)
  token     String       @unique @default(cuid())
  expiresAt DateTime
  createdAt DateTime     @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([email, status])
  @@index([orgId])
}

enum Role {
  OWNER
  MEMBER
}

model User {
  id         String   @id @default(cuid())
  authUserId String   @unique // Supabase auth user id
  email      String   @unique
  name      String?
  role      Role     @default(OWNER)
  orgId     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  signals   Signal[]
  feedback  Feedback[]

  @@index([orgId])
}

// --- Billing (V_Phase1) ---

// One row per org (provisioned FREE on first sign-in by getOrCreateAuthContext).
// Stripe is the source of truth for paid state; the webhook upserts plan/status/
// period here. `plan` is a PlanId string (see lib/billing/plans.ts); quota +
// hard spend cap are derived from the plan, not stored.
model Subscription {
  id                   String    @id @default(cuid())
  orgId                String    @unique
  plan                 String    @default("FREE") // PlanId: FREE | STARTER | PRO
  status               String    @default("active") // active | past_due | canceled
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  currentPeriodStart   DateTime  @default(now())
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

// --- Context layer (the moat) ---

model OrganizationProfile {
  id          String   @id @default(cuid())
  orgId       String   @unique
  description String   @default("")
  icp         String   @default("")
  category    String   @default("")
  positioning Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model FounderProfile {
  id             String   @id @default(cuid())
  orgId          String   @unique
  name           String   @default("")
  beliefs        Json     @default("[]") // string[]
  frameworks     Json     @default("[]") // { name, summary }[]
  lessons        Json     @default("[]") // string[]
  writingSamples Json     @default("[]") // { label, text }[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model BrandVoice {
  id              String   @id @default(cuid())
  orgId           String   @unique
  tone            String   @default("")
  sentenceStyle   String   @default("")
  bannedPhrases   String[] @default([])
  vocabulary      Json     @default("{}") // { prefer: string[], avoid: string[] }
  opinionatedness String   @default("")
  technicalDepth  String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model EditorialStrategy {
  id            String   @id @default(cuid())
  orgId         String   @unique
  pillars       Json     @default("[]") // { name, description }[]
  audiences     Json     @default("[]") // { name, description }[]
  goals         String[] @default([])
  topicsToAvoid String[] @default([])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

// --- Integrations / event ingestion (V3) ---

enum IntegrationProvider {
  GITHUB
  PIPEDRIVE
  ATTIO
  LINEAR
  WEBHOOK
}

enum ConnectionStatus {
  ACTIVE
  PAUSED
}

// A per-org connection to a third-party event source. The webhook signing
// secret is stored ENCRYPTED (see lib/crypto.ts). Inbound events hit
// /api/webhooks/[provider]/[webhookToken].
model IntegrationConnection {
  id           String              @id @default(cuid())
  orgId        String
  provider     IntegrationProvider
  status       ConnectionStatus    @default(ACTIVE)
  webhookToken String              @unique @default(cuid()) // unguessable path segment
  secret       String // provider signing secret, AES-256-GCM encrypted at rest
  config       Json                @default("{}") // event-type allowlist + thresholds
  label        String              @default("")
  createdById  String?
  lastEventAt  DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

// Dedup ledger: providers retry webhooks, so we never double-create a Signal.
// signalId is null when an event was received but filtered out (not ingested).
model IngestedEvent {
  id           String              @id @default(cuid())
  connectionId String
  provider     IntegrationProvider
  externalId   String // the provider's event id
  signalId     String?
  createdAt    DateTime            @default(now())

  // Per-connection dedup: generic/user-supplied ids can't collide across orgs.
  @@unique([connectionId, externalId])
  @@index([connectionId])
  // Supports retention pruning of this append-only ledger by age.
  @@index([createdAt])
}

// --- Pipeline ---

enum SignalSource {
  MANUAL
  GITHUB
  PIPEDRIVE
  ATTIO
  LINEAR
  WEBHOOK
}

enum SignalStatus {
  QUEUED
  NORMALIZING
  SCORING
  STORY
  NARRATIVE
  CHANNEL
  EDITING
  READY
  REJECTED
  FAILED
}

model Signal {
  id               String       @id @default(cuid())
  orgId            String
  userId           String? // null for auto-ingested signals (no human author)
  connectionId     String? // set for auto-ingested signals (IntegrationConnection)
  source           SignalSource @default(MANUAL)
  rawInput         Json // { title, description, evidence, links[], metadata }
  evidencePacket   Json? // [1] normalizer output
  status           SignalStatus @default(QUEUED)
  statusReason     String? // why rejected/failed/not-worth-publishing
  significanceScore Int? // [2]
  scoreDetail      Json? // [2] full SignalScore
  storyAngles      Json? // [3] StoryAngles
  narrativeBrief   Json? // [4] NarrativeBrief
  retrievedProof   Json? // [R] resolved memory sources cited in the brief (proof library)
  costUsd          Float        @default(0)
  deletedAt        DateTime? // V_Phase3: soft delete (Trash/restore)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user     User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  assets   ContentAsset[]
  runs     AgentRun[]
  feedback Feedback[]

  @@index([orgId, status])
  @@index([orgId, deletedAt])
  @@index([userId])
  // Attribute / look up auto-ingested signals by their source connection.
  @@index([connectionId])
}

enum Channel {
  LINKEDIN_FOUNDER
  X_THREAD
  BLOG_POST
}

enum ReviewStatus {
  PENDING
  APPROVED
  EDITED
  REJECTED
  NEEDS_WORK
}

model ContentAsset {
  id            String       @id @default(cuid())
  signalId      String
  channel       Channel
  body          Json // channel-specific structure
  antiSlopScore Int?
  antiSlopDetail Json?
  reviewStatus  ReviewStatus @default(PENDING)
  editedBody    Json?
  regenCount    Int          @default(0)
  deletedAt     DateTime? // V_Phase3: soft delete
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  signal    Signal          @relation(fields: [signalId], references: [id], onDelete: Cascade)
  feedback  Feedback[]
  scheduled ScheduledPost[]

  @@unique([signalId, channel])
  @@index([signalId])
}

// V_Phase2: in-app content calendar. There is no third-party auto-publishing yet;
// status is advanced manually (Mark posted) and a daily Inngest digest reminds
// the owner of posts due today. The queue is publish-ready for a later OAuth layer.
model ScheduledPost {
  id           String    @id @default(cuid())
  orgId        String
  assetId      String
  channel      Channel
  scheduledFor DateTime
  status       String    @default("SCHEDULED") // SCHEDULED | POSTED | CANCELED
  note         String?
  postedAt     DateTime?
  // V_Phase3: optional auto-publish (LinkedIn) by the publish-due-posts worker.
  autopublish  Boolean   @default(false)
  publishError String?
  attempts     Int       @default(0)
  createdById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  asset ContentAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([orgId, scheduledFor])
  @@index([assetId])
  // Serves the cross-tenant due-posts / digest scans that filter by
  // status + scheduledFor without an orgId (publish-due-posts, daily digest).
  @@index([status, scheduledFor])
}

// --- V_Phase3: outbound social publishing (OAuth) ---
// Dedicated outbound model (kept separate from the inbound IntegrationConnection,
// which is built around webhookToken + signing secrets). Tokens are AES-256-GCM
// encrypted at rest (lib/crypto.ts, ENCRYPTION_KEY).
enum SocialProvider {
  LINKEDIN
}

model SocialAccount {
  id           String         @id @default(cuid())
  orgId        String
  provider     SocialProvider
  status       String         @default("ACTIVE") // ACTIVE | EXPIRED | REVOKED
  externalId   String // provider member id/URN, e.g. urn:li:person:xxxx
  displayName  String         @default("")
  accessToken  String // encrypted
  refreshToken String? // encrypted (LinkedIn issues only with approval)
  expiresAt    DateTime?
  scopes       String         @default("")
  createdById  String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, provider])
  @@index([orgId])
}

// --- V_Phase3: append-only audit log ---
model AuditLog {
  id           String   @id @default(cuid())
  orgId        String
  actorId      String?
  actorEmail   String?
  action       String // "signal.deleted" | "asset.approved" | "linkedin.connected" | ...
  resourceType String?
  resourceId   String?
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
}

model AgentRun {
  id            String   @id @default(cuid())
  signalId      String
  agent         String // event_listener | significance_scorer | ...
  model         String
  promptVersion String
  inputTokens   Int      @default(0)
  outputTokens  Int      @default(0)
  cacheReadTokens Int    @default(0)
  costUsd       Float    @default(0)
  latencyMs     Int      @default(0)
  status        String // ok | error
  error         String?
  createdAt     DateTime @default(now())

  signal Signal @relation(fields: [signalId], references: [id], onDelete: Cascade)

  @@index([signalId])
}

enum FeedbackDecision {
  APPROVE
  EDIT
  REJECT
  REGENERATE
}

model Feedback {
  id        String           @id @default(cuid())
  signalId  String
  assetId   String?
  userId    String
  decision  FeedbackDecision
  notes     String?
  createdAt DateTime         @default(now())

  signal Signal        @relation(fields: [signalId], references: [id], onDelete: Cascade)
  asset  ContentAsset? @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([signalId])
}

// V2: versioned agent instructions. Global defaults in V2 (orgId nullable for
// later per-org overrides). The active version's text overrides the in-code
// INSTRUCTION; AgentRun.promptVersion records which version actually ran.
model PromptTemplate {
  id          String   @id @default(cuid())
  orgId       String?
  agent       String // event_listener | significance_scorer | story_finder | ...
  version     String // e.g. "significance_scorer.v3"
  instruction String
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())

  org Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, agent, version])
  @@index([orgId, agent, isActive])
}

// --- V5: durable memory store (Company Knowledge RAG + founder/exec POV) ---
// One typed, org-scoped vector store. Docs are chunked + embedded; per-signal
// retrieval grounds the narrative brief in cited proof.
enum MemoryKind {
  COMPANY_DOC
  CHANGELOG
  CASE_STUDY
  FOUNDER_POST
  CALL_TRANSCRIPT
  CUSTOMER_QUOTE
  OTHER
}

model MemoryDoc {
  id          String     @id @default(cuid())
  orgId       String
  kind        MemoryKind @default(COMPANY_DOC)
  title       String
  sourceUrl   String?
  rawText     String // full source text (audit + re-chunk)
  createdById String?
  deletedAt   DateTime? // V_Phase3: soft delete
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  org    Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  chunks MemoryChunk[]

  @@index([orgId, kind])
}

// embedding is declared Unsupported so Prisma creates the vector column but
// ignores it for reads/writes — chunk inserts and cosine similarity reads go
// through $executeRaw/$queryRaw (see lib/knowledge/retrieve.ts). A cosine
// ivfflat index is added by scripts/migrate-v5-pgvector.ts.
model MemoryChunk {
  id        String                      @id @default(cuid())
  docId     String
  orgId     String // denormalized for the org-scoped similarity filter
  ord       Int // chunk order within the doc
  text      String
  embedding Unsupported("vector(1536)")?
  createdAt DateTime                    @default(now())

  doc MemoryDoc @relation(fields: [docId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([docId])
}
