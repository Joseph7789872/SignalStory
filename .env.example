# --- LLM provider ---
# Which provider the agents use: "openai" or "anthropic".
# If unset, inferred from whichever key is present (OpenAI wins if only it is set).
LLM_PROVIDER=openai

# Provide the key for whichever provider(s) you use:
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model per tier (defaults are sensible).
# OpenAI defaults: gpt-4.1-mini / gpt-4.1 / gpt-4.1
# OPENAI_MODEL_EXTRACTION=gpt-4.1-mini
# OPENAI_MODEL_REASONING=gpt-4.1
# OPENAI_MODEL_WRITING=gpt-4.1
# Anthropic defaults: claude-haiku-4-5 / claude-opus-4-8 / claude-sonnet-4-6
# ANTHROPIC_MODEL_REASONING=claude-opus-4-8

# --- Supabase (Postgres database + Auth) ---
# Database → Connect → ORM/Prisma. Use the POOLED connection for DATABASE_URL
# (port 6543, add ?pgbouncer=true) and the DIRECT connection for DIRECT_URL
# (port 5432). Both include your db password and ?sslmode=require.
DATABASE_URL=postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
DIRECT_URL=postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:5432/postgres?sslmode=require

# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Inngest (durable job queue) ---
# Local dev needs NEITHER key — run `npx inngest-cli@latest dev` alongside `npm run dev`.
# Set these only in production (from the Inngest dashboard).
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Pipeline cost guardrail (USD per signal run) ---
PIPELINE_MAX_COST_USD=2.00
