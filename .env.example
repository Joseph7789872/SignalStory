# --- LLM provider ---
# Which provider the agents use: "openai" or "anthropic".
# If unset, inferred from whichever key is present (OpenAI wins if only it is set).
LLM_PROVIDER=openai

# Provide the key for whichever provider(s) you use:
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model per tier (defaults are sensible).
# OpenAI defaults: gpt-4.1-mini / gpt-4.1 / gpt-4.1
# OPENAI_MODEL_EXTRACTION=gpt-4.1-mini
# OPENAI_MODEL_REASONING=gpt-4.1
# OPENAI_MODEL_WRITING=gpt-4.1
# Anthropic defaults: claude-haiku-4-5 / claude-opus-4-8 / claude-sonnet-4-6
# ANTHROPIC_MODEL_REASONING=claude-opus-4-8

# --- Supabase (Postgres database + Auth) ---
# Database → Connect → ORM/Prisma. Use the POOLED connection for DATABASE_URL
# (port 6543, add ?pgbouncer=true) and the DIRECT connection for DIRECT_URL
# (port 5432). Both include your db password and ?sslmode=require.
DATABASE_URL=postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
DIRECT_URL=postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:5432/postgres?sslmode=require

# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Inngest (durable job queue) ---
# Local dev: set INNGEST_DEV=1 and run `npx inngest-cli@latest dev` alongside
# `npm run dev` (no keys needed). This points the SDK at the local dev server.
# In production: unset INNGEST_DEV and set the two keys (from the Inngest dashboard).
INNGEST_DEV=1
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Pipeline cost guardrail (USD per signal run) ---
PIPELINE_MAX_COST_USD=2.00

# --- Integrations (V3) ---
# Encrypts third-party webhook signing secrets at rest (AES-256-GCM).
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# --- Billing (Stripe) — Phase 1 ---
# Unset = billing disabled (routes 503, app otherwise works). Get keys from the
# Stripe dashboard; create one recurring Price per paid plan and paste its id.
# Webhook secret comes from `stripe listen` (dev) or the dashboard endpoint (prod).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# --- Rate limiting (Upstash Redis) — Phase 1 ---
# Unset = rate limiting disabled (pass-through). Create a free Upstash Redis DB
# and paste its REST url + token. Used for per-org signal submission + webhook
# flood limits (lib/ratelimit.ts).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Transactional email (Resend) — Phase 1 ---
# Unset = email disabled (no-op; invites/notifications silently skip). Get a key
# from resend.com. EMAIL_FROM must be a verified domain in prod; the resend.dev
# sandbox sender works for testing.
RESEND_API_KEY=
EMAIL_FROM="SignalStory <onboarding@resend.dev>"

# --- Error tracking (Sentry) — Phase 1 ---
# Unset = error tracking disabled (errors still log to the console). Paste the
# DSN from your Sentry project to enable capture (lib/log.ts).
SENTRY_DSN=
